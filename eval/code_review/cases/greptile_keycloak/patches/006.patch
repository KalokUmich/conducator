+        createAllUserPermission(policy, Set.of(MANAGE_GROUP_MEMBERSHIP));
+
+        //create group permission to allow manage membership for the group
+        createGroupPermission(topGroup, Set.of(MANAGE_MEMBERSHIP), policy);
